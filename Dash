<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <title>BTC/EUR Dashboard - 9 juni 2026</title>
    <style>
        body { background: #131722; color: #d1d4dc; font-family: sans-serif; padding: 20px; }
        .summary-box { background: #1c2230; padding: 20px; border-radius: 12px; border: 1px solid #ffcc00; margin-bottom: 20px; }
        .summary-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .summary-table td { padding: 8px; border-bottom: 1px solid #333; }
        .dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 20px; }
        .box { background: #1c2230; padding: 15px; border-radius: 12px; border: 1px solid #333; }
        .status-bar { margin-top: 10px; padding: 10px; background: #0b0e14; border-radius: 6px; font-size: 0.9em; border-left: 4px solid #444; }
    </style>
</head>
<body>

<div class="summary-box">
    <h2>Markt Analyse Bitcoin (9 juni 2026)</h2>
    <table class="summary-table">
        <tr><td><b>Korte Termijn:</b></td><td>🔴 <b>Bearish</b> - Hoge verkoopdruk door ETF-uitstroom en long-liquidaties.</td></tr>
        <tr><td><b>Middellange Termijn:</b></td><td>🟡 <b>Afwachten</b> - Zoektocht naar bodem in $58k - $60k zone.</td></tr>
        <tr><td><b>Lange Termijn:</b></td><td>🟢 <b>Bullish</b> - Institutionele basis blijft fundament ondersteunen.</td></tr>
    </table>
</div>

<div class="dashboard">
    <!-- Grafieken (zoals eerder geconfigureerd) -->
    <div class="box"><div id="tv-1"></div><div class="status-bar"><b>RSI:</b> Momentum neemt af bij huidige $54k koers.</div></div>
    <div class="box"><div id="tv-2"></div><div class="status-bar"><b>Trend (EMA):</b> Prijs worstelt rondom trend-gemiddelden.</div></div>
    <div class="box"><div id="tv-3"></div><div class="status-bar"><b>MACD:</b> Histogram duidt op aanhoudende verkoopdruk.</div></div>
    <div class="box"><div id="tv-4"></div><div class="status-bar"><b>Volume:</b> Let op pieken bij uitbraak uit de $58k-$60k range.</div></div>
    <div class="box"><div id="tv-5"></div><div class="status-bar"><b>VWAP:</b> Huidige prijs noteert onder de VWAP (Bearish).</div></div>
    <div class="box"><div id="tv-6"></div><div class="status-bar"><b>Sentiment:</b> Voorzichtigheid geboden; let op ETF-flows.</div></div>
</div>

<script src="https://s3.tradingview.com/tv.js"></script>
<script>
    // TradingView widgets laden...
    function createChart(c, s) { new TradingView.widget({"container_id": c, "width": "100%", "height": 300, "symbol": "COINBASE:BTCEUR", "interval": "W", "theme": "dark", "range": "all", "studies": s ? [s] : [], "allow_symbol_change": false}); }
    createChart('tv-1', 'RSI@tv-basicstudies'); createChart('tv-2', 'MAExp@tv-basicstudies'); createChart('tv-3', 'MACD@tv-basicstudies');
    createChart('tv-4', 'Volume@tv-basicstudies'); createChart('tv-5', 'VWAP@tv-basicstudies'); createChart('tv-6', null);
</script>
</body>
</html>
